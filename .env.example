# --- Orders (HTTP) ---
PORT=3000

# --- Payments (gRPC) ---
PAYMENTS_GRPC_PORT=50051
# Timeout for orders -> payments gRPC call (ms)
PAYMENTS_GRPC_TIMEOUT_MS=5000
# Bind address for payments-service
PAYMENTS_GRPC_BIND_URL=0.0.0.0:50051

# --- DB (for orders) ---
DB_HOST=orders-db.example.internal
DB_PORT=5432
DB_USER=orders_app
DB_PASSWORD=replace-with-orders-db-password
DB_NAME=orders_db

# --- DB (for payments-service) ---
PAYMENTS_DB_HOST=payments-db.example.internal
PAYMENTS_DB_PORT=5432
PAYMENTS_DB_USER=payments_app
PAYMENTS_DB_PASSWORD=replace-with-payments-db-password
PAYMENTS_DB_NAME=payments_db

# --- Auth ---
JWT_SECRET=replace-with-32-byte-random-jwt-secret
JWT_EXPIRES_IN=30m

# --- AWS / S3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=example-access-key-id
AWS_SECRET_ACCESS_KEY=example-secret-access-key
AWS_BUCKET=example-bucket-name
AWS_ENDPOINT=https://s3.example.com
CLOUDFRONT_BASE_URL=https://cdn.example.com

# --- RabbitMQ ---
RABBIT_USER=orders_app
RABBIT_PASSWORD=replace-with-rabbitmq-password
RABBIT_URL=amqp://orders_app:replace-with-rabbitmq-password@rabbitmq:5672
RABBIT_QUEUE_ORDERS=orders.process
RABBIT_QUEUE_DLQ=orders.dlq
RABBIT_RETRY_COUNT=3
RABBIT_RETRY_DELAY=1000
