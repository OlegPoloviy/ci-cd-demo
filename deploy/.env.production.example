# GitHub Environment "production" — ті самі ключі, що й у .env.stage.example; PORT зазвичай 8081 для хоста.

DB_HOST=db
DB_PORT=5432
PAYMENTS_GRPC_PORT=50051
PAYMENTS_GRPC_TIMEOUT_MS=5000
PAYMENTS_GRPC_BIND_URL=0.0.0.0:50051
DB_HOST_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
JWT_SECRET=some-strong-secret
JWT_EXPIRES_IN=30m
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_BUCKET=your-bucket
AWS_ENDPOINT=http://minio:9000
CLOUDFRONT_BASE_URL=http://localhost:9000
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBITMQ_PREFETCH=10
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBIT_QUEUE_ORDERS=orders.process
RABBIT_QUEUE_DLQ=orders.dlq
RABBIT_RETRY_COUNT=3
RABBIT_RETRY_DELAY=1000

PAYMENTS_DB_HOST=payments-db
PAYMENTS_DB_PORT=5432
PAYMENTS_DB_USER=postgres
PAYMENTS_DB_PASSWORD=postgres
PAYMENTS_DB_NAME=payments

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
PORT=8081
