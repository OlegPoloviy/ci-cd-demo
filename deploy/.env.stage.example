DB_HOST=db
DB_PORT=5432
PAYMENTS_GRPC_PORT=50051
PAYMENTS_GRPC_TIMEOUT_MS=5000
PAYMENTS_GRPC_BIND_URL=0.0.0.0:50051
DB_HOST_PORT=5432
DB_USER=orders_app
DB_PASSWORD=replace-with-stage-orders-db-password
DB_NAME=orders_db
JWT_SECRET=replace-with-stage-32-byte-random-jwt-secret
JWT_EXPIRES_IN=30m
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=example-stage-access-key-id
AWS_SECRET_ACCESS_KEY=example-stage-secret-access-key
AWS_BUCKET=stage-example-bucket
AWS_ENDPOINT=http://minio:9000
CLOUDFRONT_BASE_URL=https://stage-cdn.example.com
RABBIT_USER=orders_app
RABBIT_PASSWORD=replace-with-stage-rabbitmq-password
RABBITMQ_PREFETCH=10
RABBITMQ_URL=amqp://orders_app:replace-with-stage-rabbitmq-password@rabbitmq:5672
RABBIT_QUEUE_ORDERS=orders.process
RABBIT_QUEUE_DLQ=orders.dlq
RABBIT_RETRY_COUNT=3
RABBIT_RETRY_DELAY=1000

PAYMENTS_DB_HOST=payments-db
PAYMENTS_DB_PORT=5432
PAYMENTS_DB_USER=payments_app
PAYMENTS_DB_PASSWORD=replace-with-stage-payments-db-password
PAYMENTS_DB_NAME=payments_db

MINIO_ROOT_USER=stage-minio-root
MINIO_ROOT_PASSWORD=replace-with-stage-minio-root-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
PORT=8080
